{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "jsx": "react-jsx",
    "allowJs": false,
    "isolatedModules": false
  },
  "include": ["lib/**/*.ts", "tests/**/*.ts"]
}
